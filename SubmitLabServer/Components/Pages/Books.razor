@page "/books"
@rendermode InteractiveServer
@using SubmitLabServer.Models
@using SubmitLabServer.Services
@inject ILibraryService LibraryService

<h3>Book Management</h3>


<div class="card mb-4 p-3">
    <h5>@(editingBook == null ? "Add New Book" : "Edit Book")</h5>
    <div class="mb-2">
        <input class="form-control" placeholder="Title" @bind="formTitle" />
    </div>
    <div class="mb-2">
        <input class="form-control" placeholder="Author" @bind="formAuthor" />
    </div>
    <div class="mb-2">
        <input class="form-control" placeholder="ISBN" @bind="formISBN" />
    </div>
    <div>
        <button class="btn btn-primary me-2" @onclick="SaveBook">
            @(editingBook == null ? "Add Book" : "Save Changes")
        </button>
        @if (editingBook != null)
        {
            <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
        }
    </div>
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert alert-success mt-2">@message</div>
    }
</div>


<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in LibraryService.GetBooks())
        {
            <tr>
                <td>@book.Id</td>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.ISBN</td>
                <td>
                    <button class="btn btn-sm btn-warning me-1" @onclick="() => StartEdit(book)">Edit</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteBook(book.Id)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private string formTitle = string.Empty;
    private string formAuthor = string.Empty;
    private string formISBN = string.Empty;
    private string message = string.Empty;
    private Book? editingBook = null;

    private void SaveBook()
    {
        if (string.IsNullOrWhiteSpace(formTitle) || string.IsNullOrWhiteSpace(formAuthor) || string.IsNullOrWhiteSpace(formISBN))
        {
            message = "Please fill in all fields.";
            return;
        }

        if (editingBook == null)
        {
            LibraryService.AddBook(new Book { Title = formTitle, Author = formAuthor, ISBN = formISBN });
            message = "Book added successfully!";
        }
        else
        {
            LibraryService.EditBook(editingBook.Id, new Book { Title = formTitle, Author = formAuthor, ISBN = formISBN });
            message = "Book updated successfully!";
            editingBook = null;
        }

        formTitle = string.Empty;
        formAuthor = string.Empty;
        formISBN = string.Empty;
    }

    private void StartEdit(Book book)
    {
        editingBook = book;
        formTitle = book.Title;
        formAuthor = book.Author;
        formISBN = book.ISBN;
        message = string.Empty;
    }

    private void CancelEdit()
    {
        editingBook = null;
        formTitle = string.Empty;
        formAuthor = string.Empty;
        formISBN = string.Empty;
        message = string.Empty;
    }

    private void DeleteBook(int id)
    {
        LibraryService.DeleteBook(id);
        message = "Book deleted.";
    }
}
